# --- Secrets / keys ---
# Read-only Postgres role for the Shopify auth-hub Session table
POSTGRES_INSIGHTS_RO_URL=postgresql://insights_ro:REPLACE@127.0.0.1:5432/your_db_name

# Per-Shopify-Custom-App secrets used for HMAC verify on /shopify/webhook/{shop}.
# JSON map keyed by custom app slug. Values are the Shopify Custom App API Secret Keys.
SHOPIFY_WEBHOOK_SECRETS={"app-slug-1":"shpss_...","app-slug-2":"shpss_..."}

# --- Store registry ---
# Live store registry loaded at runtime into `ads_agent.config.STORES`.
# JSON array of objects with keys: slug, brand, shop_domain, custom_app,
# meta_ad_account (primary, or null), currency, notes (optional).
# If unset, the agent falls back to placeholder stores defined in config.py.
STORES_JSON=[{"slug":"store-a","brand":"Store A","shop_domain":"your-store-a.myshopify.com","custom_app":"store-a","meta_ad_account":"act_REPLACE","currency":"USD"}]

# Map each store slug to a list of Meta ad accounts to sum ROAS across.
# Useful when one brand runs ads through multiple ad accounts (multiple agencies,
# multiple currencies, etc.). Empty map = /roas responds "no accounts mapped".
STORE_AD_ACCOUNTS_JSON={"store-a":["act_REPLACE_PRIMARY","act_REPLACE_SECONDARY"]}

# Map each store slug to its TikTok advertiser account.
# Example:
# {"store-a":{"advertiser_id":"1234567890123456789","country":"US"}}
STORE_TIKTOK_ACCOUNTS_JSON={}

# --- Meta Marketing API (direct Graph API calls for spend + CAPI) ---
META_ADS_MCP_URL=http://127.0.0.1:3103
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# --- TikTok Business API (read-only reporting via your forked SDK) ---
# TIKTOK_ACCESS_TOKEN is an optional manual fallback token.
# TIKTOK_APP_ID / TIKTOK_APP_SECRET power the live OAuth flow at
# grow.glitchexecutor.com/tiktok/oauth/callback via /api/tiktok/consent-url.
TIKTOK_ACCESS_TOKEN=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# sandbox or production
TIKTOK_ENV=sandbox

# --- PostHog Cloud ---
# Project API key (phc_*) — used for event capture.
POSTHOG_API_KEY=phc_REPLACE
# Personal API key (phx_*) — used for HogQL read queries.
POSTHOG_PERSONAL_API_KEY=phx_REPLACE
POSTHOG_HOST=https://us.i.posthog.com

# --- Telegram bot (@YourAdsBot from @BotFather) ---
TELEGRAM_BOT_TOKEN_ADS=
# Comma-separated Telegram user IDs authorized to issue commands
TELEGRAM_ADMIN_IDS=

# --- LLM providers (LiteLLM routes across them; any one is enough) ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
# For Vertex AI mode instead of AI Studio:
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# --- Runtime ---
PUBLIC_BASE_URL=https://ads.yourdomain.com
LOG_LEVEL=INFO
