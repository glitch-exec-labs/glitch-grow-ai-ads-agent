# --- Secrets / keys ---
# Read-only Postgres role for the auth-hub Session table (create manually, SELECT on "Session" only)
POSTGRES_INSIGHTS_RO_URL=postgresql://insights_ro:REPLACE@127.0.0.1:5432/shopify_app

# Per-Shopify-Custom-App secrets used for HMAC verify on /shopify/webhook/{shop}.
# JSON map keyed by custom app slug (urban, ayurpet-ind, ayurpet, classicoo).
SHOPIFY_WEBHOOK_SECRETS={"urban":"shpss_...","ayurpet-ind":"shpss_...","ayurpet":"shpss_...","classicoo":"shpss_..."}

# Meta Ads MCP (already running locally, streamable-http)
META_ADS_MCP_URL=http://127.0.0.1:3103

# Meta Marketing API (for direct facebook-business SDK CAPI sends)
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# PostHog Cloud (free tier). Create project first, paste project API key here.
POSTHOG_API_KEY=phc_REPLACE
POSTHOG_HOST=https://us.i.posthog.com

# Telegram bot (new BotFather bot, NOT the Glitch Executor trading bot)
TELEGRAM_BOT_TOKEN_ADS=
# Comma-separated Telegram user IDs authorized to issue commands
TELEGRAM_ADMIN_IDS=

# LLM providers (LiteLLM dispatches)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# For Vertex AI mode instead of AI Studio:
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Public URL of this service (for Telegram + Shopify webhook callbacks)
PUBLIC_BASE_URL=https://insights.glitchexecutor.com

# Logging
LOG_LEVEL=INFO
