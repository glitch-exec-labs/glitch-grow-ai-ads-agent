[Unit]
Description=Glitch Grow Ads Agent — action planner (Meta write proposals)
After=network.target glitch-ads-bot.service
Wants=glitch-ads-bot.service

[Service]
Type=oneshot
User=support
Group=support
WorkingDirectory=/home/support/glitch-grow-ads-agent
EnvironmentFile=/home/support/glitch-grow-ads-agent/.env
ExecStart=/home/support/glitch-grow-ads-agent/.venv/bin/python ops/scripts/run_action_planner.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=glitch-action-planner
TimeoutStartSec=600
